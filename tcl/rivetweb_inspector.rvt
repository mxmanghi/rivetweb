<html>
    <head>
            <title>Rivetweb Page Inspector</title>
            <style>
                .rwdata td {
                    background-color: lightblue;
                }
            </style>
    </head>
    <body>
        <div><?
            if {[catch {
                parray_table ::rivetweb::content_a
            } e]} {
                ?><div class="errmsg">Error reading content_a:<? putsnnl $e ?></div><?
            }
        ?></div><div><?

            if {[catch {

                foreach mn [array names ::rivetweb::html_menu] {

                   set html_escaped($mn) "<pre>[escape_sgml_chars $::rivetweb::html_menu($mn)]</pre>"
                }

                parray_table html_escaped * "class rwdata"

            } e]} {
                ?><div>Error reading html_menu: <? putsnnl $e ?></div><?
            }

        ?></div>
    </body>
</html>
