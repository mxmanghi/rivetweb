<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<? puts [::rivetweb::contentType] ?>
<title><? puts -nonewline $::rivetweb::page_title ?></title>
<meta name="keywords" content="" />
<meta name="description" content="" />
<link href="<? puts -nonewline $::rivetweb::running_css ?>" rel="stylesheet" type="text/css" media="screen" />
</head>
<body>
<div id="wrapper">
    <? 
#       puts [$::rivetweb::pmodel languages $::rivetweb::current_pmodel] 
#       puts [dict get $::rivetweb::current_pmodel content en]
        
    ?>
	<div id="logo">
		<h1>Rivetweb</h1>
		<p><em>Simple Website creation<a href="http://www.freecsstemplates.org/"></a></em></p>
	</div>
	<hr />
	<!-- end #logo -->
	<div id="header">
		<div id="menu">
			<ul>
                <li <? puts -nonewline [::rivetweb::thisClass $::rivetweb::page_content index current_page_item] ?>>
                <a href="<? puts -nonewline [::rivetweb::makeUrl index] ?>">Home</a></li>
                <li <? puts -nonewline [::rivetweb::thisClass $::rivetweb::page_content download current_page_item] ?>>
                <a href="<? puts -nonewline [::rivetweb::makeUrl download] ?>">Downloads</a></li>
				<li></li>
                <li <? puts -nonewline [::rivetweb::thisClass $::rivetweb::page_content installation current_page_item] ?>>
                <a href="<? puts -nonewline [::rivetweb::makeUrl installation] ?>">Installation</a></li>
			</ul>
		</div>
	</div>
                <?
#                   foreach l [$::rivetweb::pmodel languages $::rivetweb::current_pmodel] {
#                       puts "<li>$l</li>"
#                   }
                ?>
	<!-- end #header -->
	<!-- end #header-wrapper -->
	<div id="page">
	<div id="page-bgtop">
    
        <div id="sidebar">
            <ul>
                <? if {[string equal $::rivetweb::page_content index] == 1} {
                 ?>
                    <!-- li>
                        <h2>23 Dec 2011</h2>
                        <p> <a href="<? puts -nonewline [::rivetweb::makeUrl dec23] ?>">Rivetweb website</a></p>
                    </li --> 
                <?
                } 
                if {[info exists ::rivetweb::html_menu(left)]} { puts $::rivetweb::html_menu(left) } 

                ?>
            </ul>
        </div>
            <!-- end #sidebar -->
        
        <div id="content">
            <div class="post">

                <h2 class="title"><a href="#"><? puts -nonewline $::rivetweb::page_headline ?></a></h2>
                <div class="entry">
                    <?

                        if {[string equal $::rivetweb::page_content index] == 1} {
                            ?><!--img src="<? puts -nonewline [::rivetweb::makePictsPath Rivetweb_tiny.png $::rivetweb::running_template] ?>" class="floatright" /--><?
                        }
                        puts $::rivetweb::page_content_html 
                    ?>
                </div>
            </div>
        </div>
        <!-- end #content -->
		
		<div style="clear: both;">&nbsp;</div>
	</div>
	</div>
	<!-- end #page -->
	<div id="footer-bgcontent">
        <div id="footer">
            <p>
                Copyright  2011 Apache Software Foundation. Design by <a href="http://www.rickyswebtemplates.com/">Ricky's Free web templates</a>.
                <a href="http://sixserve.com/"><img src="<? puts -nonewline [::rivetweb::makePictsPath big.png] ?>" /></a>
            </p>
        </div>
	</div>
	<!-- end #footer -->
</div>
<div style="text-align: center; font-size: 0.75em;">Design downloaded from <a href="http://www.freewebtemplates.com/">free website templates</a>.</div></body>
</html>
