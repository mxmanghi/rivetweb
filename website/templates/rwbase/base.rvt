<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
  <head>
	<?
	    #if {[catch { namespace eval ::rivetweb { source [file join $rivet_scripts rivet_page.tcl] } } e]} {
	    #		puts "<pre>$e</pre>"
	    #		abort_page
	    #}

	    puts [::rivetweb::contentType]
	?>
	<title><?= $::rivetweb::page_title ?></title>
	<link rel="stylesheet" href="<?= [::rivetweb::makeCssPath rivet.css $::rivetweb::template_key] ?>" />
    </head>
    <body>
	<div id="bigcontainer"> 
	    <div id="pageheadline">
		<div class="decoration">
		    <img src="<?= [::rivetweb::makePictsPath Rivetlogo_smaller.png $::rivetweb::template_key] ?>" alt="Apache Rivet" /><?= [pwd] ?>
		</div>
		<div class="headline"><? puts -nonewline $::rivetweb::page_headline ?></div>
	    </div>
	    <div id="pagecontents">
        <pre>
            <? puts "default_language: $::rivetweb::default_lang" ?>
        </pre>
		<div class="navbar navleft"><?  if {[info exists ::rivetweb::html_menu(left)]} { puts $::rivetweb::html_menu(left) } ?></div>
		<div class="navbar navright"><? if {[info exists ::rivetweb::html_menu(right)]} { puts $::rivetweb::html_menu(right) } ?></div>
		<div id="content"> 
		    <div class="contentheadline"></div>
		    <div id="maincontent" style=""><? 
#			parray ::rivetweb::html_menu
			puts $::rivetweb::page_content_html 
		    ?>
		    </div>
		    <? 
                if {[string length $::rivetweb::last_modified]} {
                    ?><div id="last_modified">Last Modified: <? puts -nonewline $::rivetweb::last_modified ?> UTC</div><?
                }
			# parray ::rivetweb::pagine 
		    ?>
		</div>
		<div class="clearfloats"></div>
		<!--div class="leftaligned">:<? puts -nonewline $::rivetweb::page_authors ?></div>
		<div class="rightaligned">:<? puts -nonewline $::rivetweb::last_modified ?></div-->
		<div>
		    <table align="center" width="100%">
			<tr>
			    <td align="left">
				<a href="http://www.apache.org/">
				<img src="<? puts -nonewline [::rivetweb::makePictsPath apache_pb.gif $::rivetweb::template_key] ?>" alt="Powered by Apache" border="0" width="259" height="32"></a>
<?  
#				if {$::rivetweb::static_links} { puts "<div><b>static</b></div>" }
#				if {$::rivetweb::is_homepage} { puts "<div><b>homepage</b></div>" }
?>
			    </td>
			    <td align="right">
					<a href="http://www.tcl.tk/">
				    	<img src="<? puts -nonewline [::rivetweb::makePictsPath tclp.gif $::rivetweb::template_key] ?>" 
				    		alt="Powered by Tcl" border="0" width="42" height="64"></a>
			    </td>
			</tr>
		    </table>
		</div>
	    </div>
	</div>
    </body>
</html>
